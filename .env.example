# Copy to .env and adjust values for your deployment.
# .env is gitignored — never commit this file with real values.
#
# Most values below are production defaults that work as-is on g4dn.xlarge.
# Only change what you need to tune.

# ── Engine settings ────────────────────────────────────────────────────────────
# Set by docker-compose.yml environment block, listed here for documentation:
#   ACCELERATOR=cuda
#   DTYPE=bfloat16

MODEL_NAME_OR_PATH=obadx/muaalem-model-v3_2
MAX_AUDIO_SECONDS=130.0
MAX_BATCH_SIZE=128
BATCH_TIMEOUT=0.4
WORKERS_PER_DEVICE=1
TIMEOUT=90.0

# ── App settings ───────────────────────────────────────────────────────────────
# ENGINE_URL is set by docker-compose.yml (http://engine:8000/predict); no need to set here.

ERROR_RATIO=0.1
# Thread counts default to cpu_count//2; override if needed:
# MAX_WORKERS_PHONETIC_SEARCH=2
# MAX_WORKERS_PHONETIZATION=2
